NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.sericia.com
NEXT_PUBLIC_CROSSMINT_CLIENT_ID=
CROSSMINT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Cinematic hero (components/CinematicHero.tsx)
# ---------------------------------------------------------------------------
# Optional bg video layer. If URL is empty, the hero renders the gradient
# only (current production default — zero CLS, zero broken state).
# Place .mp4 under /public/hero/ or an external CDN (Supabase storage / R2).
# Recommended: 1920x1080, 8–15s loop, H.264, <6MB, no audio (will be muted).
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_HERO_VIDEO_POSTER=
NEXT_PUBLIC_HERO_VIDEO_TYPE=video/mp4

# ---------------------------------------------------------------------------
# Sakura petal overlay (components/SakuraFall.tsx via CinematicHero)
# ---------------------------------------------------------------------------
# Opt-in decorative layer. Default off (nothing rendered).
# Set to "true" during spring drops / sakura-themed campaigns.
# CSS-only, ~600 bytes, no runtime cost. GPU-composited. Respects
# prefers-reduced-motion automatically.
NEXT_PUBLIC_SAKURA_ENABLED=

# ---------------------------------------------------------------------------
# PayloadCMS v3 (mounted at /cms/admin)
# ---------------------------------------------------------------------------
# 32+ char random string used to sign JWTs / encrypt sessions.
# Generate: openssl rand -base64 48
PAYLOAD_SECRET=generate-32-char-random

# Supabase Postgres connection used by Payload with schemaName=payload.
# DO NOT reuse the storefront's app.* schema — Payload owns its own schema.
# Example: postgres://USER:PASS@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?schema=payload
DATABASE_URL_PAYLOAD=

# First-run bootstrap (scripts/payload-bootstrap.ts).
# Creates an admin user on first boot IF no users exist. Safe to re-run.
PAYLOAD_ADMIN_EMAIL=admin@sericia.com
PAYLOAD_ADMIN_PASSWORD=change-me-on-first-login

# ---------------------------------------------------------------------------
# Supabase Storage (S3-compatible) for Payload Media uploads
# ---------------------------------------------------------------------------
# Supabase Project Settings > Storage > S3 Connection
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=sericia-media
SUPABASE_S3_REGION=ap-northeast-1

# ---------------------------------------------------------------------------
# Web Push (PWA drop alerts / order updates)
# ---------------------------------------------------------------------------
# Generate once per environment, then keep the SAME keypair forever: changing
# it invalidates every active subscription in the database and users have to
# re-opt-in. Rotate only on a security incident.
#
#   npx web-push generate-vapid-keys --json
#
# The public key is exposed to the browser (required by the Push API) — safe.
# The private key stays server-only. VAPID_SUBJECT is a contact URL/mailto
# the push service (Chrome FCM / Safari APNs) reaches on abuse — point it
# at an address you actually read.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@sericia.com

# ---------------------------------------------------------------------------
# pSEO pipeline (lib/deepseek.ts, lib/pseo.ts, /api/pseo/*, n8n)
# ---------------------------------------------------------------------------
# DeepSeek V3 powers editorial article generation into the Payload `articles`
# collection. The same key is reused by any other feature that calls
# lib/deepseek.ts — keep it server-only (never NEXT_PUBLIC_).
#
# Get one from https://platform.deepseek.com/api_keys — billing is usage-based.
# Context Caching discounts apply automatically when the system prompt is
# identical across requests (no flag to set). See lib/pseo.ts for the
# cacheable prompt prefix and PSEO_PROMPT_VERSION bookkeeping.
DEEPSEEK_API_KEY=

# Used by the n8n pseo-generate workflow to call our own /api/pseo/generate.
# In production this is https://sericia.com. Leave blank to let n8n fall back
# to the default inside the workflow JSON.
STOREFRONT_URL=https://sericia.com
